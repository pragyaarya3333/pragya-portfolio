{
  "name": "pragya-portfolio",
  "version": "1.0.0",
  "author": "Pragya Arya",
  "description": "Responsive frontend portfolio website customized for resume and personal projects.",
  "homepage": "https://PragyaArya3333.github.io/pragya-portfolio",
  "repository": {
    "type": "git",
    "url": "https://github.com/PragyaArya3333/pragya-portfolio.git"
  },
  "bugs": {
    "url": "https://github.com/PragyaArya3333/pragya-portfolio/issues"
  },
  "license": "UNLICENSED",
  "keywords": [
    "portfolio",
    "frontend",
    "lwc",
    "javascript",
    "html",
    "css"
  ],
  "dependencies": {
    "@salesforce-ux/design-system": "^2.14.2",
    "compression": "^1.7.4",
    "express": "^4.17.1",
    "helmet": "^4.4.1",
    "highcharts": "^9.0.1",
    "lightning-base-components": "^1.17.3-alpha"
  },
  "devDependencies": {
    "@sa11y/jest": "0.3.0",
    "@salesforce-ux/design-system": "^2.14.2",
    "@salesforce/wire-service-jest-util": "^2.4.2",
    "chart.js": "^2.9.4",
    "d3": "^6.5.0",
    "gh-pages": "^5.0.0",
    "husky": "^5.1.2",
    "jest-canvas-mock": "^2.3.1",
    "lwc-recipes-oss-ui-components": "^0.3.2",
    "lwc-services": "^3.0.4",
    "moment": "^2.29.1",
    "prettier": "^2.2.1",
    "querystring-es3": "^0.2.1"
  },
  "engines": {
    "node": "16.20.2"
  },
  "nodemonConfig": {
    "watch": [
      "src/server/**/*.js",
      "scripts/server.js"
    ],
    "ext": "js",
    "ignore": [
      "src/**/*.spec.js",
      "src/**/*.test.js"
    ],
    "exec": "node ./scripts/server.js"
  },
  "scripts": {
    "build": "lwc-services build --mode production",
    "build:development": "lwc-services build",
    "lint": "eslint ./src/**/*.js",
    "prettier": "prettier --write \"**/*.{css,html,js,json,md,yaml,yml}\"",
    "prettier:verify": "prettier --list-different \"**/*.{css,html,js,json,md,yaml,yml}\"",
    "serve": "node scripts/server.js",
    "test:unit": "lwc-services test:unit",
    "test:unit:coverage": "lwc-services test:unit --coverage",
    "test:unit:debug": "lwc-services test:unit --debug",
    "test:unit:watch": "lwc-services test:unit --watch",
    "watch": "lwc-services watch",
    "watch:production": "lwc-services watch --mode=production",
    "postinstall": "husky install",
    "precommit": "yarn prettier && yarn lint && yarn test:unit",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  }
}